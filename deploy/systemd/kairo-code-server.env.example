# /etc/default/kairo-code-server — copy to this path and set values.
# This file is sourced by the systemd unit (EnvironmentFile=).
# Keep mode 600, owner root, since it contains an API key.

# ---- Required ----
KAIRO_CODE_API_KEY=sk-replace-me

# ---- Optional: provider/model selection ----
# Defaults to OpenAI if all four are unset; ProviderRegistry knows about
# openai / anthropic / glm / qianwen.
KAIRO_PROVIDER=glm
KAIRO_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
KAIRO_MODEL=glm-5.1

# ---- Optional: session pool ----
# TTL: sessions with no chat activity for this many minutes get evicted.
KAIRO_CODE_SESSION_IDLE_TTL_MINUTES=60
# Capacity cap: past this many sessions, LRU eviction kicks in on
# createSession. Running sessions are exempt — overflow > killing in-flight
# tool calls.
KAIRO_CODE_SESSION_POOL_SIZE=64

# ---- Optional: observability (OTLP exporter) ----
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_KEY
# OTEL_SERVICE_NAME=kairo-code-server
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=prod
