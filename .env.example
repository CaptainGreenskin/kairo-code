# =============================================================================
# Kairo Code — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ---- Required ----
KAIRO_CODE_API_KEY=your-api-key-here

# ---- LLM Provider ----
# Supported: openai, qianwen (DashScope), or any OpenAI-compatible provider
KAIRO_PROVIDER=openai

# ---- LLM Model ----
# OpenAI: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# Qianwen: qwen-max, qwen-plus, qwen-turbo
KAIRO_MODEL=gpt-4o

# ---- Base URL (optional, for custom OpenAI-compatible endpoints) ----
# OpenAI default: https://api.openai.com
# DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
# KAIRO_BASE_URL=https://api.openai.com

# ---- Web UI Port (host port mapping) ----
KAIRO_WEB_PORT=3000

# ---- JVM Options (optional) ----
# JAVA_OPTS=-Xms256m -Xmx1024m
