# Kairo Code 配置文件
# 复制为 .env 并填入实际值：cp .env.example .env

# ─── 模型配置（必填）───────────────────────────────────────
KAIRO_CODE_API_KEY=your-api-key-here

# 模型选择（默认 GLM-5.1 智谱）
KAIRO_MODEL=glm-5.1
KAIRO_PROVIDER=openai
KAIRO_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# 其他 provider:
# OpenAI:    KAIRO_PROVIDER=openai     KAIRO_BASE_URL=https://api.openai.com          KAIRO_MODEL=gpt-4o
# Anthropic: KAIRO_PROVIDER=anthropic  KAIRO_BASE_URL=https://api.anthropic.com       KAIRO_MODEL=claude-sonnet-4-20250514
# 通义千问:   KAIRO_PROVIDER=qianwen   KAIRO_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  KAIRO_MODEL=qwen-max

# ─── 安全配置 ──────────────────────────────────────────────
# 共享访问 Token（团队成员在 Settings 填此值）
# 生成: openssl rand -hex 32
KAIRO_SERVER_AUTH_TOKEN=
KAIRO_SERVER_AUTH_ENABLED=true
KAIRO_SERVER_ALLOW_LOOPBACK=true
KAIRO_SERVER_ALLOWED_ORIGINS=http://localhost:3000
KAIRO_SERVER_RATE_LIMIT_RPM=240

# ─── OAuth/SSO（可选）─────────────────────────────────────
# KAIRO_SERVER_OAUTH_ENABLED=true
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── Web 端口 ─────────────────────────────────────────────
WEB_PORT=3000

# ─── 工作目录（Docker 绑定代码仓库）──────────────────────
# KAIRO_WORKSPACE_HOST=/path/to/your/project

# ─── Langfuse（可选）──────────────────────────────────────
# LANGFUSE_ENABLED=true
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
